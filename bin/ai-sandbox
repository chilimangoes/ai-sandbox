#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
IMAGE_TAG="ai-sandbox:latest"
DEFAULT_T3_CONTAINER_PORT=3773
DEFAULT_T3_HOST_PORT=3773
DEFAULT_CODENOMAD_CONTAINER_PORT=9899
DEFAULT_CODENOMAD_HOST_PORT=9899
DEFAULT_PASEO_CONTAINER_PORT=6767
DEFAULT_PASEO_HOST_PORT=6767

usage() {
  echo "Usage: ai-sandbox [--update] [--rebuild] [--t3-port <port>] [--codenomad-port <port>] [--paseo-port <port>] [shell|codex|gemini|copilot|opencode|t3|codenomad|paseo|doctor|stop|rm|reset-config|reset-state]"
}

assert_docker() {
  command -v docker >/dev/null 2>&1
  docker version >/dev/null
}

workspace_meta() {
  local workspace="$1"
  local full_path
  full_path="$(cd "$workspace" && pwd)"
  local leaf slug hash suffix container_workspace_path
  leaf="$(basename "$full_path")"
  slug="$(printf '%s' "$leaf" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')"
  [[ -n "$slug" ]] || slug="workspace"
  hash="$(printf '%s' "${full_path,,}" | sha256sum | awk '{print $1}')"
  suffix="${hash:0:12}"
  container_workspace_path="/workspace/$slug"
  printf '%s\n' "$full_path" "$slug" "$suffix" "$container_workspace_path" "ai-sandbox-$slug-$suffix" \
    "ai-sandbox-$slug-$suffix-config" "ai-sandbox-$slug-$suffix-auth" \
    "ai-sandbox-$slug-$suffix-data" "ai-sandbox-$slug-$suffix-cache"
}

free_port() {
  local start="$1"
  local port
  for ((port=start; port<start+100; port++)); do
    if command -v ss >/dev/null 2>&1; then
      if ! ss -ltn 2>/dev/null | grep -Eq "[:.]${port}[[:space:]]"; then
        echo "$port"
        return 0
      fi
    elif command -v netstat >/dev/null 2>&1; then
      if ! netstat -ltn 2>/dev/null | grep -q ":$port "; then
        echo "$port"
        return 0
      fi
    else
      echo "Neither ss nor netstat is available for port probing." >&2
      return 1
    fi
  done
  echo "No free port found starting at $start." >&2
  return 1
}

container_exists() {
  local name="$1"
  [[ "$(docker ps -a --filter "name=^/${name}$" --format '{{.Names}}')" == "$name" ]]
}

container_running() {
  local name="$1"
  [[ "$(docker ps --filter "name=^/${name}$" --format '{{.Names}}')" == "$name" ]]
}

image_id() {
  docker image inspect --format '{{.Id}}' "$1" 2>/dev/null || true
}

container_image_id() {
  docker inspect --format '{{.Image}}' "$1" 2>/dev/null || true
}

ensure_volume() {
  local name="$1"
  docker volume inspect "$name" >/dev/null 2>&1 || docker volume create "$name" >/dev/null
}

build_image() {
  docker build --pull -t "$IMAGE_TAG" "$REPO_ROOT"
}

remove_container() {
  local name="$1"
  if container_exists "$name"; then
    docker rm -f "$name" >/dev/null
  fi
}

existing_host_port() {
  local name="$1"
  local container_port="$2"
  local output
  output="$(docker port "$name" "${container_port}/tcp" 2>/dev/null || true)"
  [[ "$output" =~ :([0-9]+)$ ]] && echo "${BASH_REMATCH[1]}"
}

ensure_container() {
  local t3_host_port="$1"
  local codenomad_host_port="$2"
  local paseo_host_port="$3"

  local current_image_id
  current_image_id="$(image_id "$IMAGE_TAG")"
  [[ -n "$current_image_id" ]] || { echo "Image $IMAGE_TAG not found." >&2; exit 1; }

  if container_exists "$CONTAINER_NAME"; then
    local running_image_id
    local recreate_needed="false"
    running_image_id="$(container_image_id "$CONTAINER_NAME")"
    local current_t3_host_port
    current_t3_host_port="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_T3_CONTAINER_PORT")"
    local current_codenomad_port
    current_codenomad_port="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_CODENOMAD_CONTAINER_PORT")"
    local current_paseo_port
    current_paseo_port="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_PASEO_CONTAINER_PORT")"
    if [[ "$FORCE_RECREATE" == "true" || "$running_image_id" != "$current_image_id" ]]; then
      recreate_needed="true"
    fi
    if [[ -n "$current_t3_host_port" && "$current_t3_host_port" != "$t3_host_port" ]]; then
      recreate_needed="true"
    fi
    if [[ -n "$current_codenomad_port" && "$current_codenomad_port" != "$codenomad_host_port" ]]; then
      recreate_needed="true"
    fi
    if [[ -n "$current_paseo_port" && "$current_paseo_port" != "$paseo_host_port" ]]; then
      recreate_needed="true"
    fi
    if [[ "$recreate_needed" == "true" ]]; then
      remove_container "$CONTAINER_NAME"
    fi
  fi

  ensure_volume "$CONFIG_VOLUME"
  ensure_volume "$AUTH_VOLUME"
  ensure_volume "$DATA_VOLUME"
  ensure_volume "$CACHE_VOLUME"

  if ! container_exists "$CONTAINER_NAME"; then
    local attempt_t3_host_port="$t3_host_port"
    local attempt_codenomad_host_port="$codenomad_host_port"
    local attempt_paseo_host_port="$paseo_host_port"
    local attempt error_message
    for ((attempt=0; attempt<5; attempt++)); do
      if error_message="$(
        docker run -d \
          --name "$CONTAINER_NAME" \
          --label "ai-sandbox.workspace=${WORKSPACE_PATH}" \
          --label "ai-sandbox.hash=${WORKSPACE_HASH}" \
          -p "127.0.0.1:${attempt_t3_host_port}:${DEFAULT_T3_CONTAINER_PORT}" \
          -p "127.0.0.1:${attempt_codenomad_host_port}:${DEFAULT_CODENOMAD_CONTAINER_PORT}" \
          -p "127.0.0.1:${attempt_paseo_host_port}:${DEFAULT_PASEO_CONTAINER_PORT}" \
          -e "AI_SANDBOX_T3_PORT=${DEFAULT_T3_CONTAINER_PORT}" \
          -e "AI_SANDBOX_HOST_T3_PORT=${attempt_t3_host_port}" \
          -e "AI_SANDBOX_T3_URL=http://127.0.0.1:${attempt_t3_host_port}" \
          -e "AI_SANDBOX_CODENOMAD_PORT=${DEFAULT_CODENOMAD_CONTAINER_PORT}" \
          -e "AI_SANDBOX_HOST_CODENOMAD_PORT=${attempt_codenomad_host_port}" \
          -e "AI_SANDBOX_CODENOMAD_URL=http://127.0.0.1:${attempt_codenomad_host_port}" \
          -e "AI_SANDBOX_PASEO_PORT=${DEFAULT_PASEO_CONTAINER_PORT}" \
          -e "AI_SANDBOX_HOST_PASEO_PORT=${attempt_paseo_host_port}" \
          -e "AI_SANDBOX_PASEO_ADDRESS=127.0.0.1:${attempt_paseo_host_port}" \
          -e "AI_SANDBOX_WORKSPACE_PATH=${CONTAINER_WORKSPACE_PATH}" \
          -e "LOCAL_UID=$(id -u)" \
          -e "LOCAL_GID=$(id -g)" \
          -v "${WORKSPACE_PATH}:${CONTAINER_WORKSPACE_PATH}" \
          -v "${CONFIG_VOLUME}:/state/config" \
          -v "${AUTH_VOLUME}:/state/auth" \
          -v "${DATA_VOLUME}:/state/data" \
          -v "${CACHE_VOLUME}:/state/cache" \
          "$IMAGE_TAG" \
          daemon 2>&1 >/dev/null
      )"; then
        SELECTED_T3_HOST_PORT="$attempt_t3_host_port"
        SELECTED_CODENOMAD_HOST_PORT="$attempt_codenomad_host_port"
        SELECTED_PASEO_HOST_PORT="$attempt_paseo_host_port"
        break
      fi

      remove_container "$CONTAINER_NAME"
      if [[ "$error_message" == *"port is already allocated"* ]]; then
        attempt_t3_host_port="$(free_port "$((attempt_t3_host_port + 1))")"
        attempt_codenomad_host_port="$(free_port "$((attempt_codenomad_host_port + 1))")"
        attempt_paseo_host_port="$(free_port "$((attempt_paseo_host_port + 1))")"
        continue
      fi

      echo "$error_message" >&2
      exit 1
    done

    if ! container_exists "$CONTAINER_NAME"; then
      echo "Unable to start container after retrying host port selection." >&2
      exit 1
    fi
  elif ! container_running "$CONTAINER_NAME"; then
    docker start "$CONTAINER_NAME" >/dev/null
  fi
}

exec_in_container() {
  local interactive="$1"
  shift
  if [[ "$interactive" == "true" ]]; then
    docker exec -it \
      -e "AI_SANDBOX_T3_URL=http://127.0.0.1:${SELECTED_T3_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_T3_PORT=${SELECTED_T3_HOST_PORT}" \
      -e "AI_SANDBOX_T3_PORT=${DEFAULT_T3_CONTAINER_PORT}" \
      -e "AI_SANDBOX_CODENOMAD_URL=http://127.0.0.1:${SELECTED_CODENOMAD_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_CODENOMAD_PORT=${SELECTED_CODENOMAD_HOST_PORT}" \
      -e "AI_SANDBOX_CODENOMAD_PORT=${DEFAULT_CODENOMAD_CONTAINER_PORT}" \
      -e "AI_SANDBOX_PASEO_ADDRESS=127.0.0.1:${SELECTED_PASEO_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_PASEO_PORT=${SELECTED_PASEO_HOST_PORT}" \
      -e "AI_SANDBOX_PASEO_PORT=${DEFAULT_PASEO_CONTAINER_PORT}" \
      -e "AI_SANDBOX_WORKSPACE_PATH=${CONTAINER_WORKSPACE_PATH}" \
      "$CONTAINER_NAME" \
      /opt/ai-sandbox/entrypoint.sh "$@"
  else
    docker exec \
      -e "AI_SANDBOX_T3_URL=http://127.0.0.1:${SELECTED_T3_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_T3_PORT=${SELECTED_T3_HOST_PORT}" \
      -e "AI_SANDBOX_T3_PORT=${DEFAULT_T3_CONTAINER_PORT}" \
      -e "AI_SANDBOX_CODENOMAD_URL=http://127.0.0.1:${SELECTED_CODENOMAD_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_CODENOMAD_PORT=${SELECTED_CODENOMAD_HOST_PORT}" \
      -e "AI_SANDBOX_CODENOMAD_PORT=${DEFAULT_CODENOMAD_CONTAINER_PORT}" \
      -e "AI_SANDBOX_PASEO_ADDRESS=127.0.0.1:${SELECTED_PASEO_HOST_PORT}" \
      -e "AI_SANDBOX_HOST_PASEO_PORT=${SELECTED_PASEO_HOST_PORT}" \
      -e "AI_SANDBOX_PASEO_PORT=${DEFAULT_PASEO_CONTAINER_PORT}" \
      -e "AI_SANDBOX_WORKSPACE_PATH=${CONTAINER_WORKSPACE_PATH}" \
      "$CONTAINER_NAME" \
      /opt/ai-sandbox/entrypoint.sh "$@"
  fi
}

UPDATE="false"
REBUILD="false"
FORCE_RECREATE="false"
EXPLICIT_T3_PORT=""
EXPLICIT_CODENOMAD_PORT=""
EXPLICIT_PASEO_PORT=""
POSITIONALS=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --help)
      usage
      exit 0
      ;;
    --update)
      UPDATE="true"
      shift
      ;;
    --rebuild)
      REBUILD="true"
      FORCE_RECREATE="true"
      shift
      ;;
    --t3-port)
      EXPLICIT_T3_PORT="$2"
      shift 2
      ;;
    --codenomad-port)
      EXPLICIT_CODENOMAD_PORT="$2"
      shift 2
      ;;
    --paseo-port)
      EXPLICIT_PASEO_PORT="$2"
      shift 2
      ;;
    *)
      POSITIONALS+=("$1")
      shift
      ;;
  esac
done

COMMAND="${POSITIONALS[0]:-shell}"
COMMAND_ARGS=("${POSITIONALS[@]:1}")

assert_docker
mapfile -t META < <(workspace_meta "$PWD")
WORKSPACE_PATH="${META[0]}"
WORKSPACE_SLUG="${META[1]}"
WORKSPACE_HASH="${META[2]}"
CONTAINER_WORKSPACE_PATH="${META[3]}"
CONTAINER_NAME="${META[4]}"
CONFIG_VOLUME="${META[5]}"
AUTH_VOLUME="${META[6]}"
DATA_VOLUME="${META[7]}"
CACHE_VOLUME="${META[8]}"

if [[ -z "$(image_id "$IMAGE_TAG")" || "$UPDATE" == "true" || "$REBUILD" == "true" ]]; then
  build_image
fi

case "$COMMAND" in
  stop)
    container_exists "$CONTAINER_NAME" && docker stop "$CONTAINER_NAME" >/dev/null || true
    exit 0
    ;;
  rm)
    remove_container "$CONTAINER_NAME"
    exit 0
    ;;
  reset-state)
    remove_container "$CONTAINER_NAME"
    docker volume rm "$CONFIG_VOLUME" "$AUTH_VOLUME" "$DATA_VOLUME" "$CACHE_VOLUME" >/dev/null 2>&1 || true
    exit 0
    ;;
esac

if [[ "$REBUILD" == "true" ]]; then
  remove_container "$CONTAINER_NAME"
fi

if container_exists "$CONTAINER_NAME"; then
  EXISTING_T3_PORT="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_T3_CONTAINER_PORT")"
  EXISTING_CODENOMAD_PORT="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_CODENOMAD_CONTAINER_PORT")"
  EXISTING_PASEO_PORT="$(existing_host_port "$CONTAINER_NAME" "$DEFAULT_PASEO_CONTAINER_PORT")"
else
  EXISTING_T3_PORT=""
  EXISTING_CODENOMAD_PORT=""
  EXISTING_PASEO_PORT=""
fi

if [[ -n "$EXPLICIT_T3_PORT" ]]; then
  SELECTED_T3_HOST_PORT="$EXPLICIT_T3_PORT"
elif [[ -n "$EXISTING_T3_PORT" ]]; then
  SELECTED_T3_HOST_PORT="$EXISTING_T3_PORT"
else
  SELECTED_T3_HOST_PORT="$(free_port "$DEFAULT_T3_HOST_PORT")"
fi

if [[ -n "$EXPLICIT_CODENOMAD_PORT" ]]; then
  SELECTED_CODENOMAD_HOST_PORT="$EXPLICIT_CODENOMAD_PORT"
elif [[ -n "$EXISTING_CODENOMAD_PORT" ]]; then
  SELECTED_CODENOMAD_HOST_PORT="$EXISTING_CODENOMAD_PORT"
else
  SELECTED_CODENOMAD_HOST_PORT="$(free_port "$DEFAULT_CODENOMAD_HOST_PORT")"
fi

if [[ -n "$EXPLICIT_PASEO_PORT" ]]; then
  SELECTED_PASEO_HOST_PORT="$EXPLICIT_PASEO_PORT"
elif [[ -n "$EXISTING_PASEO_PORT" ]]; then
  SELECTED_PASEO_HOST_PORT="$EXISTING_PASEO_PORT"
else
  SELECTED_PASEO_HOST_PORT="$(free_port "$DEFAULT_PASEO_HOST_PORT")"
fi

ensure_container "$SELECTED_T3_HOST_PORT" "$SELECTED_CODENOMAD_HOST_PORT" "$SELECTED_PASEO_HOST_PORT"

case "$COMMAND" in
  reset-config)
    exec_in_container false reset-config
    ;;
  doctor)
    exec_in_container false doctor
    ;;
  t3|codenomad|paseo)
    exec_in_container false "$COMMAND" "${COMMAND_ARGS[@]}"
    ;;
  shell)
    exec_in_container true shell
    ;;
  *)
    exec_in_container true "$COMMAND" "${COMMAND_ARGS[@]}"
    ;;
esac
